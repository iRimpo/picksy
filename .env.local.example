# ─── Supabase (Analytics) ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# ─── Existing API keys ─────────────────────────────────────────────────────────
TAVILY_API_KEY=
GEMINI_API_KEY=

# ─── Product Images (pick one or more — tried in priority order) ───────────────

# Option A — Google Custom Search Images (100 free/day, best quality)
# 1. Go to https://programmablesearchengine.google.com → create engine → "Search entire web"
# 2. Google Cloud Console → enable "Custom Search API" → create API key
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# Option B — Bing Image Search (1,000 free/month via Azure free tier)
# Azure portal → Cognitive Services → Bing Search v7 → free tier
BING_SEARCH_API_KEY=

# Tavily (already set above) is used as final fallback automatically.

# ─── Affiliate / Revenue (add when enrolled) ───────────────────────────────────
# Amazon Associates: https://affiliate-program.amazon.com → get your tag
NEXT_PUBLIC_AMAZON_TAG=
